# ─────────────────────────────────────────────
# 프런트엔드(빌드 시 주입) — Vite는 VITE_ 접두사만 노출
# ─────────────────────────────────────────────
# Supabase 프로젝트 (기존 rest 계열과 동일 프로젝트 사용 가능)
VITE_SUPABASE_URL=https://hcmgdztsgjvzcyxyayaj.supabase.co
VITE_SUPABASE_ANON_KEY=여기에_anon_public_key

# 챗봇 Edge Function 이름 (기본: chat)
VITE_CHAT_FUNCTION=chat

# ─────────────────────────────────────────────
# Supabase Edge Function 서버 시크릿 (브라우저에 노출되지 않음)
#   설정:  supabase secrets set OPENAI_API_KEY=sk-...
#   이 값들은 .env가 아니라 Supabase 시크릿으로 등록한다.
# ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
